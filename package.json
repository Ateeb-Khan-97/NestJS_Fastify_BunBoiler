{
	"name": "nest-js-fastify",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "bun ./scripts/build.ts",
		"dev": "bun --watch src/main.ts",
		"start": "./dist/server",
		"format": "bunx biome format --write ./src",
		"lint": "bunx biome check ./src",
		"prepare": "husky",
		"postinstall": "bunx --bun prisma generate",
		"db:generate": "bunx --bun prisma generate",
		"db:migrate": "bunx --bun prisma migrate dev",
		"db:deploy": "bunx --bun prisma migrate deploy",
		"db:push": "bunx --bun prisma db push",
		"db:studio": "bunx --bun prisma studio"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"prisma": "^7.8.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@fastify/cookie": "^11.0.2",
		"@nestjs/axios": "^4.0.1",
		"@nestjs/common": "^11.1.9",
		"@nestjs/core": "^11.1.9",
		"@nestjs/jwt": "^11.0.1",
		"@nestjs/platform-fastify": "^11.1.9",
		"@nestjs/swagger": "^11.2.1",
		"@nestjs/terminus": "^11.0.0",
		"@nestjs/throttler": "^6.4.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@scalar/nestjs-api-reference": "^1.0.7",
		"axios": "^1.13.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.2",
		"fastify": "^5.6.2",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"zod": "^4.1.12"
	}
}
