generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  runtime    = "bun"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  fullName  String
  email     String    @unique
  password  String

  @@map("users")
}
